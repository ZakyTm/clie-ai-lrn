---
interface Props {
  activeTab?: 'home' | 'knowledge' | 'domains' | 'search';
}

const { activeTab } = Astro.props;
---

<header class="sticky top-0 z-40 w-full border-b border-subtle bg-canvas/80 backdrop-blur-md transition-colors duration-normal">
  <div class="container-site flex h-16 items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center space-x-2 font-mono text-sm tracking-wider uppercase font-bold text-primary">
      <span class="text-accent">$</span>
      <span>AI_ENGINEERING_HUB</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-8 font-mono text-xs tracking-widest uppercase">
      <a 
        href="/" 
        class={`hover:text-accent transition-colors duration-fast ${activeTab === 'home' ? 'text-accent border-b border-accent pb-1' : 'text-secondary'}`}
      >
        [01] HOME
      </a>
      <a 
        href="/knowledge" 
        class={`hover:text-accent transition-colors duration-fast ${activeTab === 'knowledge' ? 'text-accent border-b border-accent pb-1' : 'text-secondary'}`}
      >
        [02] MANUAL
      </a>
      <a 
        href="/domains" 
        class={`hover:text-accent transition-colors duration-fast ${activeTab === 'domains' ? 'text-accent border-b border-accent pb-1' : 'text-secondary'}`}
      >
        [03] DOMAINS
      </a>
      <a 
        href="/search" 
        class={`hover:text-accent transition-colors duration-fast ${activeTab === 'search' ? 'text-accent border-b border-accent pb-1' : 'text-secondary'}`}
      >
        [04] SEARCH
      </a>
    </nav>

    <!-- Right Controls -->
    <div class="flex items-center space-x-4">
      <!-- Theme Toggle -->
      <button 
        id="theme-toggle" 
        class="p-2 border border-subtle rounded-md hover:bg-surface hover:text-accent text-secondary transition-all duration-fast"
        aria-label="Toggle Theme"
        type="button"
      >
        <!-- Sun Icon (shown in dark theme) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2"/>
          <path d="M12 20v2"/>
          <path d="m4.93 4.93 1.41 1.41"/>
          <path d="m17.66 17.66 1.41 1.41"/>
          <path d="M2 12h2"/>
          <path d="M20 12h2"/>
          <path d="m6.34 17.66-1.41 1.41"/>
          <path d="m19.07 4.93-1.41 1.41"/>
        </svg>
        <!-- Moon Icon (shown in light theme) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-moon">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>

      <!-- GitHub Link -->
      <a 
        href="https://github.com/DietrichGebert/ponytail" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hidden sm:inline-flex items-center justify-center p-2 border border-subtle rounded-md hover:bg-surface hover:text-accent text-secondary transition-all duration-fast"
        aria-label="GitHub Repository"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
      </a>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-toggle" 
        class="md:hidden p-2 border border-subtle rounded-md hover:bg-surface text-secondary"
        aria-label="Open Menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-subtle bg-canvas px-4 py-4 transition-colors duration-normal">
    <nav class="flex flex-col space-y-4 font-mono text-xs tracking-widest uppercase">
      <a href="/" class={`hover:text-accent py-2 ${activeTab === 'home' ? 'text-accent font-bold' : 'text-secondary'}`}>
        [01] HOME
      </a>
      <a href="/knowledge" class={`hover:text-accent py-2 ${activeTab === 'knowledge' ? 'text-accent font-bold' : 'text-secondary'}`}>
        [02] MANUAL
      </a>
      <a href="/domains" class={`hover:text-accent py-2 ${activeTab === 'domains' ? 'text-accent font-bold' : 'text-secondary'}`}>
        [03] DOMAINS
      </a>
      <a href="/search" class={`hover:text-accent py-2 ${activeTab === 'search' ? 'text-accent font-bold' : 'text-secondary'}`}>
        [04] SEARCH
      </a>
      <a 
        href="https://github.com/DietrichGebert/ponytail" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hover:text-accent py-2 border-t border-subtle text-secondary"
      >
        [05] GITHUB ↗
      </a>
    </nav>
  </div>
</header>

<style>
  /* Toggle icon visibility based on data-theme */
  .theme-icon-sun {
    display: none;
  }
  .theme-icon-moon {
    display: block;
  }
  :global([data-theme="dark"]) .theme-icon-sun {
    display: block;
  }
  :global([data-theme="dark"]) .theme-icon-moon {
    display: none;
  }
</style>

<script>
  // Mobile Menu Logic
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Theme Toggle Logic
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('hub:theme', newTheme);
    });
  }
</script>
