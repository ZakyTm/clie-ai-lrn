---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="py-3 font-mono text-[11px] uppercase tracking-wider text-secondary">
  <ol class="flex flex-wrap items-center space-x-2">
    <!-- Home base node -->
    <li>
      <a href="/" class="hover:text-accent transition-colors duration-fast text-muted">INDEX</a>
    </li>
    
    {items.map((item, index) => (
      <li class="flex items-center space-x-2">
        <span class="text-muted font-normal select-none">/</span>
        {item.href && index < items.length - 1 ? (
          <a href={item.href} class="hover:text-accent transition-colors duration-fast text-muted">
            {item.label}
          </a>
        ) : (
          <span class="text-primary font-medium" aria-current="page">
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
