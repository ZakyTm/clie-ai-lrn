---
import type { Resource } from '../../types';
import allResources from '../../data/resources.json';

interface Props {
  resourceIds: string[];
}

const { resourceIds } = Astro.props;

// Resolve resource objects
const resources = resourceIds
  .map(id => allResources.find((r: any) => r.id === id))
  .filter((r): r is Resource => !!r);

// Helper to determine icon for resource type
function getResourceIcon(type: string) {
  switch (type) {
    case 'github':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/></svg>`;
    case 'paper':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
    case 'doc':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`;
    case 'video':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`;
    case 'tool':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`;
    default: // article
      return `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5z"/></svg>`;
  }
}
---

{resources.length === 0 ? (
  <div class="figure-frame p-6 text-center text-muted font-mono text-xs">
    <div class="figure-corner figure-corner--tl"></div>
    <div class="figure-corner figure-corner--tr"></div>
    <div class="figure-corner figure-corner--bl"></div>
    <div class="figure-corner figure-corner--br"></div>
    NO_RESOURCES_AVAILABLE
  </div>
) : (
  <ul class="space-y-4">
    {resources.map(res => (
      <li class="figure-frame group p-4 hover:border-accent hover:bg-surface/30 transition-all duration-fast">
        <div class="figure-corner figure-corner--tl"></div>
        <div class="figure-corner figure-corner--tr"></div>
        <div class="figure-corner figure-corner--bl"></div>
        <div class="figure-corner figure-corner--br"></div>
        
        <div class="flex items-start gap-4">
          <!-- Resource Type Icon -->
          <div 
            class="flex-shrink-0 p-2 border border-subtle bg-surface text-muted rounded-md group-hover:text-accent group-hover:border-accent transition-colors"
            Fragment set:html={getResourceIcon(res.type)}
          />
          
          <div class="flex-grow">
            <!-- Header/Link -->
            <h4 class="text-sm font-serif font-bold leading-snug">
              <a href={res.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline flex items-center gap-1.5">
                {res.title}
                <span class="inline-block text-[9px] font-mono text-muted no-underline select-none">↗</span>
              </a>
            </h4>
            
            <!-- Description -->
            {res.description && (
              <p class="text-secondary text-xs font-serif mt-1">
                {res.description}
              </p>
            )}
            
            <!-- Footer tags -->
            <div class="flex flex-wrap gap-2 mt-3 font-mono text-[9px] text-muted">
              <span class="uppercase">[{res.type}]</span>
              {res.tags.map(tag => (
                <span>#{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </li>
    ))}
  </ul>
)}
