---
import type { Concept } from '../../types';
import allConcepts from '../../data/concepts.json';

interface Props {
  relatedIds: string[];
  currentId: string;
}

const { relatedIds, currentId } = Astro.props;

// Resolve related concepts
// We search for exact matches in id, or matching tags/domains if no explicit related ids are set
let related = relatedIds
  .map(id => allConcepts.find((c: any) => c.id === id))
  .filter((c): c is Concept => !!c && c.id !== currentId);

// If no explicit related concepts, fall back to matching domains
if (related.length === 0) {
  const currentConcept = allConcepts.find((c: any) => c.id === currentId) as Concept | undefined;
  if (currentConcept) {
    related = allConcepts
      .filter((c: any) => c.id !== currentId && c.domains.some((d: string) => currentConcept.domains.includes(d)))
      .slice(0, 3) as Concept[];
  }
}
---

{related.length === 0 ? null : (
  <div class="figure-frame p-6 bg-surface/20">
    <div class="figure-corner figure-corner--tl"></div>
    <div class="figure-corner figure-corner--tr"></div>
    <div class="figure-corner figure-corner--bl"></div>
    <div class="figure-corner figure-corner--br"></div>

    <h3 class="font-mono text-xs uppercase tracking-widest text-muted border-b border-subtle pb-3 mb-4">
      // RELATED_CONCEPTS
    </h3>

    <ul class="space-y-3 font-serif">
      {related.map(item => (
        <li>
          <a href={`/knowledge/${item.id}`} class="block group">
            <h4 class="text-sm font-bold group-hover:text-accent group-hover:underline leading-snug">
              {item.title}
            </h4>
            <p class="text-muted text-xs line-clamp-1 mt-0.5">
              {item.summary}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
