---
import type { Concept } from '../../types';

interface Props {
  concept: Concept;
}

const { concept } = Astro.props;

const formattedDate = new Date(concept.lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const difficultyClasses = {
  beginner: 'text-[var(--success)] border-[var(--success)] bg-[var(--success)]/5',
  intermediate: 'text-[var(--accent)] border-[var(--accent)] bg-[var(--accent)]/5',
  advanced: 'text-[var(--error)] border-[var(--error)] bg-[var(--error)]/5'
};
---

<div class="figure-frame p-6 bg-surface/50">
  <div class="figure-corner figure-corner--tl"></div>
  <div class="figure-corner figure-corner--tr"></div>
  <div class="figure-corner figure-corner--bl"></div>
  <div class="figure-corner figure-corner--br"></div>

  <div class="font-mono text-xs uppercase tracking-widest text-muted border-b border-subtle pb-3 mb-4">
    // METADATA_MANUAL
  </div>

  <div class="space-y-4 font-mono text-xs">
    <!-- Difficulty -->
    <div class="flex items-center justify-between py-1 border-b border-subtle/30">
      <span class="text-muted">DIFFICULTY:</span>
      <span class={`px-2 py-0.5 border rounded-sm font-semibold uppercase tracking-wider text-[10px] ${difficultyClasses[concept.difficulty]}`}>
        {concept.difficulty}
      </span>
    </div>

    <!-- Read Time -->
    <div class="flex items-center justify-between py-1 border-b border-subtle/30">
      <span class="text-muted">READ_TIME:</span>
      <span class="text-primary font-bold">{concept.readTimeMinutes} MIN</span>
    </div>

    <!-- Source -->
    <div class="flex items-center justify-between py-1 border-b border-subtle/30">
      <span class="text-muted">SOURCE:</span>
      <span class="text-primary">
        {concept.sourceRepo === 'manual' ? (
          <span class="text-accent font-bold">MANUAL_REWRITE</span>
        ) : (
          <a href="https://github.com/rohitg00/ai-engineering-from-scratch" target="_blank" rel="noopener noreferrer" class="underline hover:text-accent">
            UPSTREAM_REPO ↗
          </a>
        )}
      </span>
    </div>

    <!-- Last Updated -->
    <div class="flex items-center justify-between py-1 border-b border-subtle/30">
      <span class="text-muted">LAST_MODIFIED:</span>
      <span class="text-secondary">{formattedDate}</span>
    </div>

    <!-- Tags -->
    {concept.tags.length > 0 && (
      <div class="pt-2">
        <span class="text-muted block mb-2 uppercase">TAGS:</span>
        <div class="flex flex-wrap gap-1.5">
          {concept.tags.map(tag => (
            <span class="px-1.5 py-0.5 border border-subtle bg-canvas text-secondary rounded-sm text-[10px] uppercase">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </div>
</div>
