---
import '../styles/global.css';
import SearchModal from '../components/layout/SearchModal.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = "Clie-AI-LRN Hub",
  description = "A conceptual-first directory of AI engineering patterns, tools, and foundations. Styled like pi.dev.",
  image = "/og-image.png",
  type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://aiengineeringhub.netlify.app');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Theme Initialization Script (blocking in head to avoid flash of color) -->
    <script is:inline>
      (function () {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('hub:theme')) {
            return localStorage.getItem('hub:theme');
          }
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            return 'light';
          }
          return 'dark'; // Default to dark (pi.dev default)
        })();

        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-canvas text-primary selection:bg-selection-bg">
    <slot />
    <SearchModal />
  </body>
</html>
