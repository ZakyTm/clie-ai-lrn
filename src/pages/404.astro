---
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
---

<Base title="404: Entry Not Found — AI Engineering Hub" description="Error 404: The manual page requested could not be located.">
  <Header />

  <main class="flex-grow container-site py-16 flex items-center justify-center">
    <div class="figure-frame p-8 max-w-lg w-full bg-deep border-[var(--error)]/40 text-left">
      <div class="figure-corner figure-corner--tl"></div>
      <div class="figure-corner figure-corner--tr"></div>
      <div class="figure-corner figure-corner--bl"></div>
      <div class="figure-corner figure-corner--br"></div>

      <div class="font-mono text-xs text-[var(--error)] mb-6 uppercase tracking-widest font-bold">
        // SYSTEM_FATAL_ERROR: 404
      </div>

      <div class="font-mono text-sm space-y-4 mb-8">
        <div class="flex items-center gap-2">
          <span class="text-muted">$</span>
          <span class="text-primary font-bold">man query_entry</span>
        </div>
        <div class="text-[var(--error)]">
          No manual entry for requested resource.
        </div>
        <div class="text-muted text-xs">
          The concept ID requested does not match any compiled schema in domains.json or concepts.json.
        </div>
      </div>

      <div class="flex flex-wrap gap-4 font-mono text-xs uppercase pt-4 border-t border-subtle">
        <a 
          href="/" 
          class="px-4 py-2 border border-subtle hover:border-accent hover:text-accent rounded transition-all"
        >
          [RETURN_INDEX]
        </a>
        <a 
          href="/search" 
          class="px-4 py-2 border border-accent bg-accent-muted text-accent hover:bg-accent/25 hover:text-accent-hover rounded transition-all"
        >
          [EXECUTE_SEARCH]
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
