---
import Base from '../../layouts/Base.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import ConceptCard from '../../components/concept/ConceptCard.astro';

import domains from '../../data/domains.json';
import concepts from '../../data/concepts.json';

export async function getStaticPaths() {
  return domains.map((domain: any) => ({
    params: { domain: domain.id },
    props: { domain }
  }));
}

const { domain } = Astro.props;

// Filter concepts for this domain
const domainConcepts = concepts.filter((c: any) => c.domains.includes(domain.id));
---

<Base 
  title={`${domain.title} — AI Engineering Hub`} 
  description={domain.description}
>
  <Header activeTab="domains" />

  <main class="flex-grow container-site py-8">
    <Breadcrumb 
      items={[
        { label: 'DOMAINS', href: '/domains' },
        { label: domain.title }
      ]} 
    />

    <!-- Header Section -->
    <header class="mb-10 max-w-3xl">
      <div class="font-mono text-xs text-accent uppercase tracking-wider mb-2">
        // SECTION_0{domain.order}
      </div>
      <h1 class="font-serif text-3xl md:text-4xl font-bold mb-3">
        {domain.title}
      </h1>
      <p class="text-secondary text-base font-serif leading-relaxed">
        {domain.description}
      </p>
    </header>

    <!-- Concepts Grid -->
    {domainConcepts.length === 0 ? (
      <div class="figure-frame p-12 text-center text-muted font-mono text-xs">
        <div class="figure-corner figure-corner--tl"></div>
        <div class="figure-corner figure-corner--tr"></div>
        <div class="figure-corner figure-corner--bl"></div>
        <div class="figure-corner figure-corner--br"></div>
        NO_CONCEPTS_IN_THIS_DOMAIN
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {domainConcepts.map((concept: any) => (
          <ConceptCard concept={concept} />
        ))}
      </div>
    )}
  </main>

  <Footer />
</Base>
