---
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import terms from '../data/terms.json';

// Group terms by section
const uniqueSections = [...new Set(terms.map((t: any) => t.section))];
uniqueSections.sort((a: string, b: string) => {
  const numA = parseInt(a.match(/Section\s+(\d+)/)?.[1] || '999', 10);
  const numB = parseInt(b.match(/Section\s+(\d+)/)?.[1] || '999', 10);
  return numA - numB;
});

const sections = uniqueSections.map((sect) => {
  const sectTerms = terms.filter((t: any) => t.section === sect);
  const numMatch = sect.match(/Section\s+(\d+)/);
  const num = numMatch ? parseInt(numMatch[1], 10) : 99;
  return {
    id: `section-${num}`,
    num,
    title: sect,
    terms: sectTerms
  };
});
---

<Base title="AI Engineering Glossary" description="Complete dictionary of modern AI coding concepts and jargon in plain English.">
  <Header activeTab="glossary" />

  <main class="flex-grow container-site py-8">
    <Breadcrumb items={[{ label: 'GLOSSARY', href: '/glossary' }]} />

    <section class="max-w-3xl mt-8 mb-12">
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-2">// DICTIONARY_MANUAL</p>
      <h1 class="font-serif text-3xl md:text-5xl font-bold mb-4">
        AI Engineering Dictionary
      </h1>
      <p class="text-secondary text-base font-serif leading-relaxed">
        A structured reference index explaining emerging AI terms, architecture patterns, failure modes, and developer conventions. Use the homepage console for instant interactive search, or browse the sections below.
      </p>
    </section>

    <!-- Sections Loop -->
    <div class="space-y-12 max-w-4xl">
      {sections.map(section => (
        <section id={section.id} class="border-t border-subtle/50 pt-8 group">
          <div class="flex flex-col md:flex-row gap-6">
            <!-- Section Header -->
            <div class="md:w-1/3">
              <span class="font-mono text-xs text-accent block mb-2">§{section.num < 10 ? '0' + section.num : section.num}</span>
              <h2 class="font-serif text-xl font-bold text-primary mb-2">
                {section.title}
              </h2>
              <span class="font-mono text-[10px] text-muted">
                {section.terms.length} entries compiled
              </span>
            </div>

            <!-- Section Terms Grid -->
            <div class="md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-4">
              {section.terms.map((term: any) => (
                <a 
                  href={`/term/${term.id}`} 
                  class="figure-frame p-4 hover:border-accent hover:bg-surface/20 transition-all duration-fast block relative"
                >
                  <div class="figure-corner figure-corner--tl"></div>
                  <div class="figure-corner figure-corner--tr"></div>
                  <div class="figure-corner figure-corner--bl"></div>
                  <div class="figure-corner figure-corner--br"></div>
                  
                  <div class="flex justify-between items-start gap-2 mb-1.5">
                    <span class="font-mono text-xs text-primary font-bold hover:underline">
                      {term.title}
                    </span>
                    <span class={`font-mono text-[8px] px-1.5 py-0.5 rounded border ${
                      term.sourceRepo === 'manual' 
                        ? 'text-green-400 bg-green-500/5 border-green-500/20' 
                        : 'text-yellow-500 bg-yellow-500/5 border-yellow-500/20'
                    }`}>
                      {term.sourceRepo === 'manual' ? 'verified' : 'local-ref'}
                    </span>
                  </div>
                  <span class="text-secondary text-[11px] font-serif line-clamp-2 leading-relaxed">
                    {term.summary}
                  </span>
                </a>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>

  <Footer />
</Base>
