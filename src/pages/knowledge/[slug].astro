---
import Base from '../../layouts/Base.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';

import ConceptMeta from '../../components/concept/ConceptMeta.astro';
import ResourceList from '../../components/concept/ResourceList.astro';
import RelatedConcepts from '../../components/concept/RelatedConcepts.astro';

import concepts from '../../data/concepts.json';
import { marked } from 'marked';

export async function getStaticPaths() {
  return concepts.map((concept: any) => ({
    params: { slug: concept.id },
    props: { concept }
  }));
}

const { concept } = Astro.props;

// Compile markdown body to HTML at build time
const parsedBody = marked.parse(concept.body || '');
---

<Base 
  title={`${concept.title} — AI Engineering Manual`} 
  description={concept.summary}
>
  <Header activeTab="knowledge" />

  <main class="flex-grow container-site py-8">
    <!-- Navigation / Breadcrumbs -->
    <Breadcrumb 
      items={[
        { label: 'MANUAL', href: '/knowledge' },
        { label: concept.title }
      ]} 
    />

    <!-- Header Section -->
    <header class="mb-8 border-b border-subtle pb-6">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        {concept.domains.map((domainId: string) => (
          <a 
            href={`/domains/${domainId}`} 
            class="font-mono text-xs uppercase tracking-wider text-accent hover:underline"
          >
            @{domainId}
          </a>
        ))}
      </div>
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight text-primary">
        {concept.title}
      </h1>
    </header>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content (Left Column) -->
      <div class="lg:col-span-2">
        <!-- Summary Callout -->
        <div class="figure-frame p-6 mb-8 border-accent-border/40 bg-accent-surface">
          <div class="figure-corner figure-corner--tl"></div>
          <div class="figure-corner figure-corner--tr"></div>
          <div class="figure-corner figure-corner--bl"></div>
          <div class="figure-corner figure-corner--br"></div>
          
          <div class="font-mono text-[10px] tracking-widest text-accent uppercase mb-2">
            // BRIEF_SYNOPSIS
          </div>
          <p class="font-serif text-base italic leading-relaxed text-primary">
            {concept.summary}
          </p>
        </div>

        <!-- Compiled HTML Content -->
        <article class="prose-manual" set:html={parsedBody} />
      </div>

      <!-- Sidebar Controls (Right Column) -->
      <div class="space-y-6">
        <!-- Metadata Info -->
        <ConceptMeta concept={concept} />

        <!-- Related concepts list -->
        <RelatedConcepts relatedIds={concept.related} currentId={concept.id} />

        <!-- Additional resources block -->
        <div>
          <h3 class="font-mono text-xs uppercase tracking-widest text-muted mb-3">// REFERENCE_RESOURCES</h3>
          <ResourceList resourceIds={concept.resources} />
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style is:global>
  /* Custom prose styling to match the pi.dev terminal-serif aesthetic */
  .prose-manual {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--text-primary);
  }

  .prose-manual h1,
  .prose-manual h2,
  .prose-manual h3,
  .prose-manual h4 {
    font-family: var(--font-serif);
    font-weight: bold;
    color: var(--text-primary);
    margin-top: 1.8em;
    margin-bottom: 0.6em;
    line-height: 1.3;
  }

  .prose-manual h1 { font-size: 1.75rem; border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.3em; }
  .prose-manual h2 { font-size: 1.45rem; border-bottom: 1px solid var(--border-subtle)/50; padding-bottom: 0.2em; }
  .prose-manual h3 { font-size: 1.2rem; }
  .prose-manual h4 { font-size: 1rem; }

  .prose-manual p {
    margin-bottom: 1.25em;
  }

  .prose-manual ul,
  .prose-manual ol {
    margin-bottom: 1.25em;
    padding-left: 1.5rem;
  }

  .prose-manual li {
    margin-bottom: 0.4em;
  }

  .prose-manual blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    color: var(--text-secondary);
    font-style: italic;
    margin: 1.5em 0;
  }

  .prose-manual pre {
    margin: 1.5em 0;
  }

  .prose-manual table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .prose-manual th,
  .prose-manual td {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-subtle);
  }

  .prose-manual th {
    background-color: var(--bg-surface);
    font-weight: bold;
  }
</style>
