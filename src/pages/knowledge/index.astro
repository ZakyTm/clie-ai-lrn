---
import Base from '../../layouts/Base.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';

import concepts from '../../data/concepts.json';
import domains from '../../data/domains.json';

// Group domains for filter list
---

<Base title="Concept Directory — AI Engineering Hub" description="Browse all 600+ AI engineering concepts, terms, myths and lessons.">
  <Header activeTab="knowledge" />

  <main class="flex-grow container-site py-8">
    <Breadcrumb items={[{ label: 'MANUAL', href: '/knowledge' }]} />

    <div class="mb-8">
      <h1 class="font-serif text-3xl font-bold mb-2">Concept Manual</h1>
      <p class="text-secondary text-sm font-serif">
        Search and filter through the complete database of AI terminology, lessons, and patterns.
      </p>
    </div>

    <!-- Filter Dashboard -->
    <div class="figure-frame p-6 mb-8 bg-surface/30">
      <div class="figure-corner figure-corner--tl"></div>
      <div class="figure-corner figure-corner--tr"></div>
      <div class="figure-corner figure-corner--bl"></div>
      <div class="figure-corner figure-corner--br"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-mono text-xs">
        <!-- Search Input -->
        <div class="flex flex-col gap-2">
          <label for="search-input" class="text-muted font-bold">QUERY_FILTER:</label>
          <div class="flex items-center gap-2 border border-subtle bg-canvas px-3 py-2 rounded-md">
            <span class="text-accent">$</span>
            <input 
              type="text" 
              id="search-input" 
              placeholder="Type to filter..." 
              class="bg-transparent border-none outline-none text-primary w-full placeholder:text-muted"
            />
          </div>
        </div>

        <!-- Domain Selection -->
        <div class="flex flex-col gap-2">
          <label for="domain-select" class="text-muted font-bold">DOMAIN_FILTER:</label>
          <select 
            id="domain-select" 
            class="border border-subtle bg-canvas text-primary px-3 py-2 rounded-md outline-none"
          >
            <option value="all">ALL DOMAINS</option>
            {domains.map(d => (
              <option value={d.id}>{d.title.toUpperCase()}</option>
            ))}
          </select>
        </div>

        <!-- Difficulty Selection -->
        <div class="flex flex-col gap-2">
          <label for="difficulty-select" class="text-muted font-bold">DIFFICULTY_FILTER:</label>
          <select 
            id="difficulty-select" 
            class="border border-subtle bg-canvas text-primary px-3 py-2 rounded-md outline-none"
          >
            <option value="all">ALL DIFFICULTIES</option>
            <option value="beginner">BEGINNER</option>
            <option value="intermediate">INTERMEDIATE</option>
            <option value="advanced">ADVANCED</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Concept count -->
    <div class="font-mono text-xs text-muted mb-4 flex justify-between">
      <span>MATCH_COUNT: <span id="concept-count" class="text-primary font-bold">{concepts.length}</span> / {concepts.length}</span>
      <span class="text-[9px]">PRESS_SLASH_FOR_SEARCH</span>
    </div>

    <!-- Table Directory -->
    <div class="figure-frame overflow-hidden">
      <div class="figure-corner figure-corner--tl"></div>
      <div class="figure-corner figure-corner--tr"></div>
      <div class="figure-corner figure-corner--bl"></div>
      <div class="figure-corner figure-corner--br"></div>

      <div class="overflow-x-auto">
        <table class="w-full text-left font-mono text-xs border-collapse">
          <thead>
            <tr class="bg-surface border-b border-subtle text-muted">
              <th class="p-3 uppercase">Name</th>
              <th class="p-3 uppercase hidden sm:table-cell">Domains</th>
              <th class="p-3 uppercase">Difficulty</th>
              <th class="p-3 uppercase hidden md:table-cell">Source</th>
              <th class="p-3 uppercase text-right">Read Time</th>
            </tr>
          </thead>
          <tbody id="concept-table-body" class="divide-y divide-subtle/30">
            {concepts.map((concept: any) => (
              <tr 
                class="hover:bg-surface/40 transition-colors concept-row"
                data-id={concept.id}
                data-title={concept.title.toLowerCase()}
                data-summary={concept.summary.toLowerCase()}
                data-tags={concept.tags.join(' ').toLowerCase()}
                data-domains={concept.domains.join(',')}
                data-difficulty={concept.difficulty}
              >
                <!-- Name -->
                <td class="p-3 font-serif text-sm font-bold text-primary group">
                  <a href={`/knowledge/${concept.id}`} class="hover:text-accent hover:underline block">
                    {concept.title}
                  </a>
                  <span class="block sm:hidden font-mono text-[9px] text-muted mt-0.5">
                    {concept.domains.join(', ').toUpperCase()}
                  </span>
                </td>
                
                <!-- Domains -->
                <td class="p-3 text-muted hidden sm:table-cell text-[10px]">
                  {concept.domains.map((d: string) => `@${d}`).join(', ').toUpperCase()}
                </td>
                
                <!-- Difficulty -->
                <td class="p-3">
                  <span class={`px-1.5 py-0.5 border rounded-sm font-semibold text-[9px] uppercase 
                    ${concept.difficulty === 'beginner' ? 'text-[var(--success)] border-[var(--success)]/30 bg-[var(--success)]/5' : 
                      concept.difficulty === 'intermediate' ? 'text-[var(--accent)] border-[var(--accent)]/30 bg-[var(--accent)]/5' : 
                      'text-[var(--error)] border-[var(--error)]/30 bg-[var(--error)]/5'}`}
                  >
                    {concept.difficulty}
                  </span>
                </td>
                
                <!-- Source -->
                <td class="p-3 text-secondary hidden md:table-cell text-[10px]">
                  {concept.sourceRepo === 'manual' ? 'MANUAL' : 'UPSTREAM'}
                </td>
                
                <!-- Read time -->
                <td class="p-3 text-right text-muted">
                  {concept.readTimeMinutes} MIN
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<script>
  // Browser search filtering
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const domainSelect = document.getElementById('domain-select') as HTMLSelectElement | null;
  const difficultySelect = document.getElementById('difficulty-select') as HTMLSelectElement | null;
  const rows = document.querySelectorAll('.concept-row') as NodeListOf<HTMLTableRowElement>;
  const countEl = document.getElementById('concept-count');

  function filterTable() {
    const query = searchInput?.value.toLowerCase().trim() || '';
    const selectedDomain = domainSelect?.value || 'all';
    const selectedDifficulty = difficultySelect?.value || 'all';
    
    let visibleCount = 0;

    rows.forEach(row => {
      const title = row.getAttribute('data-title') || '';
      const summary = row.getAttribute('data-summary') || '';
      const tags = row.getAttribute('data-tags') || '';
      const rowDomains = row.getAttribute('data-domains')?.split(',') || [];
      const rowDifficulty = row.getAttribute('data-difficulty') || '';
      
      const queryMatches = !query || 
        title.includes(query) || 
        summary.includes(query) || 
        tags.includes(query);
      
      const domainMatches = selectedDomain === 'all' || rowDomains.includes(selectedDomain);
      const difficultyMatches = selectedDifficulty === 'all' || rowDifficulty === selectedDifficulty;

      if (queryMatches && domainMatches && difficultyMatches) {
        row.style.display = '';
        visibleCount++;
      } else {
        row.style.display = 'none';
      }
    });

    if (countEl) {
      countEl.textContent = visibleCount.toString();
    }
  }

  // Bind event listeners
  searchInput?.addEventListener('input', filterTable);
  domainSelect?.addEventListener('change', filterTable);
  difficultySelect?.addEventListener('change', filterTable);

  // Global keybind: slash '/' to focus search
  window.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput?.focus();
    }
  });
</script>
