---
import Base from '../../layouts/Base.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import terms from '../../data/terms.json';
import { Marked } from 'marked';

export async function getStaticPaths() {
  return terms.map((term: any) => ({
    params: { slug: term.id },
    props: { term }
  }));
}

const { term } = Astro.props;
const marked = new Marked();

// Parse markdown to HTML strings
const bodyHtml = marked.parse(term.body || '');
const avoidHtml = term.avoid ? marked.parse(term.avoid) : '';
const usageHtml = term.usage ? marked.parse(term.usage) : '';

// Resolve related terms objects
const relatedTerms = term.related
  .map((id: string) => terms.find((t: any) => t.id === id))
  .filter(Boolean);
---

<Base title={`${term.title} — AI Manual`} description={term.summary}>
  <Header activeTab="glossary" />

  <main class="flex-grow container-site py-8">
    <Breadcrumb 
      items={[
        { label: 'GLOSSARY', href: '/glossary' },
        { label: term.title.toUpperCase(), href: `/term/${term.id}` }
      ]} 
    />

    <article class="max-w-3xl mt-8">
      <!-- Section / Domain Label -->
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-2">
        // {term.section} · {term.readTimeMinutes} MIN READ
      </p>

      <!-- Legal Compliance Banner -->
      {term.sourceRepo === 'reference' ? (
        <div class="mb-8 border border-red-500/20 bg-red-500/5 p-4 rounded-md font-mono text-[11px] text-red-400">
          <span class="font-bold text-red-500">[!] LOCAL DEVELOPMENT REFERENCE</span> — This content is derived from ZakyTm/dictionary-of-ai-coding for structural reference. It must be rewritten in our own words and cited before public deployment.
        </div>
      ) : (
        <div class="mb-8 border border-green-500/20 bg-green-500/5 p-4 rounded-md font-mono text-[11px] text-green-400">
          <span class="font-bold text-green-500">[✓] VERIFIED MANUAL ENTRY</span> — This concept has been rewritten from primary sources and is legally cleared for production.
        </div>
      )}

      <!-- Term Title -->
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 text-primary">
        {term.title}
      </h1>

      <!-- Synopsis/Summary -->
      <div class="font-serif text-lg md:text-xl text-secondary leading-relaxed italic border-l-2 border-accent/30 pl-4 mb-8">
        {term.summary}
      </div>

      <!-- Main Prose Description -->
      <section class="prose prose-custom font-serif text-base md:text-lg text-primary leading-relaxed mb-12">
        <Fragment set:html={bodyHtml} />
      </section>

      <!-- AVOID Card -->
      {term.avoid && (
        <section class="figure-frame p-6 bg-red-500/5 border-red-500/20 mb-8 relative">
          <div class="figure-corner figure-corner--tl"></div>
          <div class="figure-corner figure-corner--tr"></div>
          <div class="figure-corner figure-corner--bl"></div>
          <div class="figure-corner figure-corner--br"></div>
          <h2 class="font-mono text-xs text-red-500 uppercase tracking-widest mb-3"># AVOID</h2>
          <div class="prose prose-custom text-secondary text-sm font-serif leading-relaxed">
            <Fragment set:html={avoidHtml} />
          </div>
        </section>
      )}

      <!-- USAGE Dialog Box -->
      {term.usage && (
        <section class="figure-frame p-6 bg-surface mb-12 relative">
          <div class="figure-corner figure-corner--tl"></div>
          <div class="figure-corner figure-corner--tr"></div>
          <div class="figure-corner figure-corner--bl"></div>
          <div class="figure-corner figure-corner--br"></div>
          <h2 class="font-mono text-xs text-accent uppercase tracking-widest mb-3"># USAGE</h2>
          <div class="prose prose-custom text-primary text-sm font-mono leading-relaxed bg-canvas/30 p-4 border border-subtle/50 rounded overflow-x-auto whitespace-pre-wrap">
            <Fragment set:html={usageHtml} />
          </div>
        </section>
      )}

      <!-- SEE ALSO Section Links -->
      {relatedTerms.length > 0 && (
        <section class="border-t border-subtle/50 pt-8 mt-12">
          <h2 class="font-mono text-xs uppercase tracking-widest text-muted mb-4">// SEE_ALSO</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedTerms.map((t: any) => (
              <a href={`/term/${t.id}`} class="figure-frame p-4 hover:border-accent hover:bg-surface/20 transition-all duration-fast block">
                <div class="figure-corner figure-corner--tl"></div>
                <div class="figure-corner figure-corner--tr"></div>
                <div class="figure-corner figure-corner--bl"></div>
                <div class="figure-corner figure-corner--br"></div>
                <span class="font-mono text-xs text-accent block font-bold mb-1">{t.title}</span>
                <span class="text-secondary text-[11px] font-serif line-clamp-1">{t.summary}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Contribution & Quiz Prompter Banner -->
      <div class="border-t border-dashed border-subtle/50 pt-8 mt-12 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-xs font-mono">
        <div class="flex flex-wrap gap-3">
          <button 
            id="copy-quiz-prompt" 
            class="px-3.5 py-1.5 border border-accent bg-accent-muted text-accent hover:bg-accent/25 rounded transition-all font-bold uppercase flex items-center gap-1.5 cursor-pointer"
            data-term-title={term.title}
          >
            <span>[QUIZ_ME_PROMPT 📋]</span>
          </button>
        </div>
        <a 
          href={`https://github.com/ZakyTm/ai-engineering-manual/edit/main/src/data/manual-concepts/${term.id}.md`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-3.5 py-1.5 border border-subtle hover:border-accent hover:text-accent rounded transition-all uppercase text-secondary"
        >
          [EDIT_THIS_TERM_ON_GITHUB ↗]
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Base>

<script>
  const copyBtn = document.getElementById('copy-quiz-prompt');
  if (copyBtn) {
    const termTitle = copyBtn.getAttribute('data-term-title');
    const promptText = `Act as an expert Socratic AI Engineering Tutor. Quiz me on the concept of "${termTitle}". Ask me exactly 3 questions: one conceptual, one code architecture scenario, and one troubleshooting/debugging question. Ask me the questions one at a time, wait for my response to each, grade my answers strictly, and explain any gaps in my understanding before moving to the next question.`;
    
    copyBtn.addEventListener('click', () => {
      const copyText = (text: string) => {
        if (navigator.clipboard && window.isSecureContext) {
          return navigator.clipboard.writeText(text);
        } else {
          const textArea = document.createElement('textarea');
          textArea.value = text;
          textArea.style.position = 'fixed';
          textArea.style.left = '-9999px';
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand('copy');
          } catch (err) {
            console.error('Fallback copy failed', err);
          }
          document.body.removeChild(textArea);
          return Promise.resolve();
        }
      };

      copyText(promptText).then(() => {
        const originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span>[COPIED_TO_CLIPBOARD! ✓]</span>';
        copyBtn.classList.add('border-green-500', 'text-green-500');
        setTimeout(() => {
          copyBtn.innerHTML = originalText;
          copyBtn.classList.remove('border-green-500', 'text-green-500');
        }, 2000);
      }).catch((err) => {
        console.error('Failed to copy text', err);
      });
    });
  }
</script>
