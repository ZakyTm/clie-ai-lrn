---
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';

import concepts from '../data/concepts.json';

// Minimal search structure we can send to client
const searchData = concepts.map((c: any) => ({
  id: c.id,
  title: c.title,
  summary: c.summary,
  domains: c.domains,
  difficulty: c.difficulty,
  tags: c.tags
}));
---

<Base title="Search the Manual — AI Engineering Hub" description="Instant query search across the entire manual database.">
  <Header activeTab="search" />

  <main class="flex-grow container-site py-8">
    <Breadcrumb items={[{ label: 'SEARCH', href: '/search' }]} />

    <div class="mb-8">
      <h1 class="font-serif text-3xl font-bold mb-2">Search Console</h1>
      <p class="text-secondary text-sm font-serif">
        Query the compiled manual indexing all 600+ conceptual entities.
      </p>
    </div>

    <!-- Search Terminal Box -->
    <div class="figure-frame p-6 bg-deep border-accent-border/40 mb-8">
      <div class="figure-corner figure-corner--tl"></div>
      <div class="figure-corner figure-corner--tr"></div>
      <div class="figure-corner figure-corner--bl"></div>
      <div class="figure-corner figure-corner--br"></div>

      <div class="font-mono text-xs text-muted mb-3 uppercase tracking-wider">
        // INTERACTIVE_TERM_QUERY
      </div>
      
      <div class="flex items-center gap-3 border border-subtle bg-canvas/40 px-4 py-3 rounded-md font-mono text-sm">
        <span class="text-accent font-bold select-none">$ QUERY_CONSOLE:</span>
        <input 
          type="text" 
          id="query-console-input" 
          placeholder="e.g. RAG, Agents, CUDA..." 
          class="bg-transparent border-none outline-none text-primary w-full placeholder:text-muted/65"
          autofocus
        />
      </div>
    </div>

    <!-- Search status info -->
    <div class="font-mono text-xs text-muted mb-6 flex flex-wrap justify-between gap-2 border-b border-subtle/30 pb-2">
      <div>
        STATUS: <span id="search-status" class="text-primary font-bold">READY</span>
      </div>
      <div>
        RESULTS: <span id="results-count" class="text-primary font-bold">0</span>
      </div>
      <div>
        TIME: <span id="search-time" class="text-primary font-bold">0ms</span>
      </div>
    </div>

    <!-- Results Listing -->
    <div id="results-list" class="space-y-4">
      <div class="figure-frame p-12 text-center text-muted font-mono text-xs bg-surface/15">
        <div class="figure-corner figure-corner--tl"></div>
        <div class="figure-corner figure-corner--tr"></div>
        <div class="figure-corner figure-corner--bl"></div>
        <div class="figure-corner figure-corner--br"></div>
        ENTER_QUERY_FOR_DB_LOOKUP
      </div>
    </div>
  </main>

  <Footer />
</Base>

<!-- Inject search data as JSON safely -->
<script define:vars={{ searchData }}>
  const queryInput = document.getElementById('query-console-input');
  const resultsList = document.getElementById('results-list');
  const statusEl = document.getElementById('search-status');
  const countEl = document.getElementById('results-count');
  const timeEl = document.getElementById('search-time');

  function renderResultItem(item) {
    const difficultyClasses = {
      beginner: 'text-[var(--success)] border-[var(--success)]/30 bg-[var(--success)]/5',
      intermediate: 'text-[var(--accent)] border-[var(--accent)]/30 bg-[var(--accent)]/5',
      advanced: 'text-[var(--error)] border-[var(--error)]/30 bg-[var(--error)]/5'
    };

    const domainList = item.domains.map(d => `@${d.toUpperCase()}`).join(' ');

    return `
      <div class="figure-frame p-6 hover:border-accent hover:bg-surface/10 transition-all duration-fast">
        <div class="figure-corner figure-corner--tl"></div>
        <div class="figure-corner figure-corner--tr"></div>
        <div class="figure-corner figure-corner--bl"></div>
        <div class="figure-corner figure-corner--br"></div>
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-3">
          <h3 class="text-lg font-serif font-bold">
            <a href="/knowledge/${item.id}" class="hover:text-accent hover:underline">
              ${item.title}
            </a>
          </h3>
          <div class="flex items-center gap-2 font-mono text-[10px]">
            <span class="px-1.5 py-0.5 border rounded-sm font-semibold uppercase ${difficultyClasses[item.difficulty]}">
              ${item.difficulty}
            </span>
            <span class="text-muted">${domainList}</span>
          </div>
        </div>

        <p class="text-secondary text-sm font-serif mb-4 line-clamp-2">
          ${item.summary}
        </p>

        <div class="flex flex-wrap gap-1.5 mt-2">
          ${item.tags.map(t => `<span class="font-mono text-[9px] text-muted">#${t.toUpperCase()}</span>`).join(' ')}
        </div>
      </div>
    `;
  }

  function handleSearch() {
    const query = queryInput.value.toLowerCase().trim();
    
    if (!query) {
      statusEl.textContent = 'READY';
      countEl.textContent = '0';
      timeEl.textContent = '0ms';
      resultsList.innerHTML = `
        <div class="figure-frame p-12 text-center text-muted font-mono text-xs bg-surface/15">
          <div class="figure-corner figure-corner--tl"></div>
          <div class="figure-corner figure-corner--tr"></div>
          <div class="figure-corner figure-corner--bl"></div>
          <div class="figure-corner figure-corner--br"></div>
          ENTER_QUERY_FOR_DB_LOOKUP
        </div>
      `;
      return;
    }

    statusEl.textContent = 'SEARCHING';
    const start = performance.now();

    // Query match score calculation
    const matched = [];
    for (const item of searchData) {
      const title = item.title.toLowerCase();
      const summary = item.summary.toLowerCase();
      
      let score = 0;
      if (title === query) score += 100;
      else if (title.startsWith(query)) score += 50;
      else if (title.includes(query)) score += 20;
      
      if (summary.includes(query)) score += 5;
      
      // Tag matches
      item.tags.forEach(tag => {
        if (tag.toLowerCase() === query) score += 15;
      });

      if (score > 0) {
        matched.push({ item, score });
      }
    }

    // Sort by match quality
    matched.sort((a, b) => b.score - a.score);

    const end = performance.now();
    const duration = Math.round(end - start);

    timeEl.textContent = `${duration}ms`;
    countEl.textContent = matched.length.toString();
    statusEl.textContent = 'COMPLETED';

    if (matched.length === 0) {
      resultsList.innerHTML = `
        <div class="figure-frame p-12 text-center text-[var(--error)] font-mono text-xs bg-[var(--error)]/5">
          <div class="figure-corner figure-corner--tl"></div>
          <div class="figure-corner figure-corner--tr"></div>
          <div class="figure-corner figure-corner--bl"></div>
          <div class="figure-corner figure-corner--br"></div>
          NO_RESULTS_FOUND_FOR_QUERY: "${query}"
        </div>
      `;
    } else {
      resultsList.innerHTML = matched.map(m => renderResultItem(m.item)).join('');
    }
  }

  queryInput.addEventListener('input', handleSearch);
</script>
