# AI Engineering Hub - Environment Variables Template
# Copy this file to .env locally. DO NOT commit the .env file.

# Required for Phase 2: GitHub API integration (build-time metadata collection)
# Obtain from GitHub Settings > Developer Settings > Personal Access Tokens
GITHUB_TOKEN=

# Required for Phase 3: Anthropic Claude API (generating summaries at build time)
# Obtain from the Anthropic Console
ANTHROPIC_API_KEY=
